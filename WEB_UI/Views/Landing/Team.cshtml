@{
    Layout = "../Shared/_Layout_Public.cshtml";
    ViewData["Title"] = "Equipo";
}

<!-- SECCIÓN 1 · HERO -->
<section class="psa-team-hero text-white py-6">
    <div class="container text-center">
        <span class="badge bg-white text-primary px-3 py-2 rounded-pill mb-3 fs-6">
            <i class="bi bi-people-fill me-1"></i>Equipo de Desarrollo
        </span>
        <h1 class="display-4 fw-bold mb-3">
            Las personas detrás del<br/>
            <span class="text-warning">Sistema Nativa</span>
        </h1>
        <p class="lead text-white-75 col-md-6 mx-auto mb-5">
            Un equipo multidisciplinario comprometido con construir una plataforma
            tecnológica sólida para la conservación ambiental de Costa Rica.
        </p>
        <div class="d-flex justify-content-center flex-wrap gap-4">
            <div class="text-center">
                <div class="fw-bold fs-3">4</div>
                <div class="text-white-75 small">Integrantes</div>
            </div>
            <div class="vr"></div>
            <div class="text-center">
                <div class="fw-bold fs-3">.NET 10</div>
                <div class="text-white-75 small">Tecnología base</div>
            </div>
            <div class="vr"></div>
            <div class="text-center">
                <div class="fw-bold fs-3">Scrum</div>
                <div class="text-white-75 small">Metodología</div>
            </div>
            <div class="vr"></div>
            <div class="text-center">
                <div class="fw-bold fs-3">Azure</div>
                <div class="text-white-75 small">Cloud</div>
            </div>
        </div>
    </div>
</section>

<!-- SECCIÓN 2 · NUESTRA MISIÓN -->
<section class="py-6 bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <span class="badge text-bg-primary px-3 py-2 rounded-pill mb-3">Nuestra misión</span>
                <h2 class="display-6 fw-bold mb-4">
                    Tecnología al servicio de la <span class="text-success">naturaleza</span>
                </h2>
                <p class="text-muted mb-4">
                    Somos un equipo de estudiantes universitarios apasionados por la tecnología y el
                    impacto social. Nuestro objetivo es desarrollar una plataforma web robusta, accesible
                    y confiable que facilite el proceso de Pago por Servicios Ambientales en Costa Rica,
                    conectando a propietarios de tierras con Ingenieros Forestales certificados.
                </p>
                <div class="row g-3 text-start mt-2">
                    <div class="col-md-4">
                        <div class="d-flex align-items-start gap-3 p-3 bg-white rounded-3 shadow-sm h-100">
                            <i class="bi bi-bullseye fs-3 text-primary mt-1 flex-shrink-0"></i>
                            <div>
                                <div class="fw-semibold">Enfoque</div>
                                <div class="text-muted small">Solución real para una institución costarricense, no solo un proyecto académico.</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="d-flex align-items-start gap-3 p-3 bg-white rounded-3 shadow-sm h-100">
                            <i class="bi bi-award fs-3 text-success mt-1 flex-shrink-0"></i>
                            <div>
                                <div class="fw-semibold">Calidad</div>
                                <div class="text-muted small">Código limpio, pruebas unitarias y arquitectura en capas.</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="d-flex align-items-start gap-3 p-3 bg-white rounded-3 shadow-sm h-100">
                            <i class="bi bi-lightning-charge fs-3 text-warning mt-1 flex-shrink-0"></i>
                            <div>
                                <div class="fw-semibold">Agilidad</div>
                                <div class="text-muted small">Sprints semanales con revisión continua y entrega incremental.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SECCIÓN 3 · EL EQUIPO --> 
<section class="py-6" id="equipo">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge text-bg-success px-3 py-2 rounded-pill mb-3">El equipo</span>
            <h2 class="display-6 fw-bold">Conoce a nuestros <span class="text-primary">integrantes</span></h2>
        </div>
        <div class="row g-4 justify-content-center">

            <!-- Bryan Millon -->
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100 psa-team-card">
                    <div class="card-body p-4">
                        <div class="psa-avatar bg-info text-white mx-auto mb-3">BM</div>
                        <h5 class="fw-bold mb-1">Bryan Millon Ojeda</h5>
                        <div class="badge text-bg-info px-3 py-2 mb-3">
                            <i class="bi bi-database me-1"></i>Base de Datos
                        </div>
                        <p class="text-muted small mb-3">
                            Responsable del diseño y modelado de la base de datos SQL Server,
                            migraciones con EF Core 10 y optimización de consultas.
                        </p>
                        <div class="d-flex flex-wrap justify-content-center gap-1">
                            <span class="badge border border-info text-info small">SQL Server</span>
                            <span class="badge border border-info text-info small">EF Core 10</span>
                            <span class="badge border border-info text-info small">T-SQL</span>
                        </div>
                    </div>
                    <div class="card-footer bg-info bg-opacity-10 border-0 py-2">
                        <small class="text-info"><i class="bi bi-server me-1"></i>Database Engineer</small>
                    </div>
                </div>
            </div>

            <!-- Alexandra Zeledón -->
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100 psa-team-card">
                    <div class="card-body p-4">
                        <div class="psa-avatar bg-danger text-white mx-auto mb-3">AZ</div>
                        <h5 class="fw-bold mb-1">Alexandra Zeledón Ovares</h5>
                        <div class="badge text-bg-danger px-3 py-2 mb-3">
                            <i class="bi bi-kanban me-1"></i>Scrum Master & QA
                        </div>
                        <p class="text-muted small mb-3">
                            Lidera la metodología ágil del equipo, coordina sprints, retrospectivas
                            y garantiza la calidad con pruebas xUnit y Moq.
                        </p>
                        <div class="d-flex flex-wrap justify-content-center gap-1">
                            <span class="badge border border-danger text-danger small">Scrum</span>
                            <span class="badge border border-danger text-danger small">xUnit</span>
                            <span class="badge border border-danger text-danger small">Moq</span>
                        </div>
                    </div>
                    <div class="card-footer bg-danger bg-opacity-10 border-0 py-2">
                        <small class="text-danger"><i class="bi bi-shield-check me-1"></i>Scrum Master / QA</small>
                    </div>
                </div>
            </div>

            <!-- Erick Masís -->
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100 psa-team-card">
                    <div class="card-body p-4">
                        <div class="psa-avatar bg-warning text-dark mx-auto mb-3">EM</div>
                        <h5 class="fw-bold mb-1">Erick Masís Cavero</h5>
                        <div class="badge text-bg-warning px-3 py-2 mb-3">
                            <i class="bi bi-code-slash me-1"></i>Back End
                        </div>
                        <p class="text-muted small mb-3">
                            Desarrolla la lógica de negocio, servicios REST, motor de cálculo PSA,
                            integración Azure Blob Storage y Hosted Services.
                        </p>
                        <div class="d-flex flex-wrap justify-content-center gap-1">
                            <span class="badge border border-warning text-warning small">ASP.NET</span>
                            <span class="badge border border-warning text-warning small">Azure</span>
                            <span class="badge border border-warning text-warning small">MailKit</span>
                        </div>
                    </div>
                    <div class="card-footer bg-warning bg-opacity-10 border-0 py-2">
                        <small class="text-warning"><i class="bi bi-server me-1"></i>Back End Developer</small>
                    </div>
                </div>
            </div>

            <!-- Jonathan Méndez -->
            <div class="col-sm-6 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 text-center h-100 psa-team-card">
                    <div class="card-body p-4">
                        <div class="psa-avatar bg-success text-white mx-auto mb-3">JM</div>
                        <h5 class="fw-bold mb-1">Jonathan Méndez Herrera</h5>
                        <div class="badge text-bg-success px-3 py-2 mb-3">
                            <i class="bi bi-palette me-1"></i>Front End
                        </div>
                        <p class="text-muted small mb-3">
                            Diseña y desarrolla la interfaz de usuario, vistas Razor, JavaScript
                            con patrón constructor-function y accesibilidad WCAG 2.1 AA.
                        </p>
                        <div class="d-flex flex-wrap justify-content-center gap-1">
                            <span class="badge border border-success text-success small">Razor/MVC</span>
                            <span class="badge border border-success text-success small">Bootstrap</span>
                            <span class="badge border border-success text-success small">jQuery</span>
                        </div>
                    </div>
                    <div class="card-footer bg-success bg-opacity-10 border-0 py-2">
                        <small class="text-success"><i class="bi bi-layout-text-window me-1"></i>Front End Developer</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SECCIÓN 4 · STACK TECNOLÓGICO -->
<section class="py-6 bg-light" id="tecnologias">
    <div class="container">
        <div class="text-center mb-5">
            <span class="badge text-bg-primary px-3 py-2 rounded-pill mb-3">Stack tecnológico</span>
            <h2 class="display-6 fw-bold">Herramientas que <span class="text-primary">usamos</span></h2>
        </div>
        <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 p-3 text-center psa-tech-card h-100">
                    <i class="bi bi-microsoft fs-2 text-primary mb-2"></i>
                    <div class="fw-semibold small">.NET 10 / ASP.NET Core MVC</div>
                    <div class="text-muted small">Framework principal</div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 p-3 text-center psa-tech-card h-100">
                    <i class="bi bi-database fs-2 text-danger mb-2"></i>
                    <div class="fw-semibold small">SQL Server + EF Core 10</div>
                    <div class="text-muted small">Base de datos</div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 p-3 text-center psa-tech-card h-100">
                    <i class="bi bi-cloud fs-2 text-info mb-2"></i>
                    <div class="fw-semibold small">Azure Cloud Storage</div>
                    <div class="text-muted small">Almacenamiento de archivos</div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 p-3 text-center psa-tech-card h-100">
                    <i class="bi bi-bootstrap fs-2 text-purple mb-2" style="color:#7952b3"></i>
                    <div class="fw-semibold small">Bootstrap + Minty</div>
                    <div class="text-muted small">Diseño UI</div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 p-3 text-center psa-tech-card h-100">
                    <i class="bi bi-geo-alt fs-2 text-success mb-2"></i>
                    <div class="fw-semibold small">Leaflet.js</div>
                    <div class="text-muted small">Mapas interactivos</div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 p-3 text-center psa-tech-card h-100">
                    <i class="bi bi-bar-chart-line fs-2 text-warning mb-2"></i>
                    <div class="fw-semibold small">Chart.js</div>
                    <div class="text-muted small">Dashboards y gráficos</div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 p-3 text-center psa-tech-card h-100">
                    <i class="bi bi-envelope fs-2 text-danger mb-2"></i>
                    <div class="fw-semibold small">MailKit / SMTP</div>
                    <div class="text-muted small">Notificaciones por correo</div>
                </div>
            </div>
            <div class="col-6 col-md-4 col-lg-3">
                <div class="card border-0 shadow-sm rounded-3 p-3 text-center psa-tech-card h-100">
                    <i class="bi bi-check2-square fs-2 text-primary mb-2"></i>
                    <div class="fw-semibold small">xUnit + Moq</div>
                    <div class="text-muted small">Pruebas unitarias</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SECCIÓN 5 · METODOLOGÍA SCRUM -->
<section class="py-6" id="metodologia">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="badge text-bg-warning px-3 py-2 rounded-pill mb-3">Metodología</span>
                <h2 class="display-6 fw-bold mb-4">
                    Trabajamos con <span class="text-primary">Scrum</span>
                </h2>
                <p class="text-muted mb-4">
                    Adoptamos la metodología ágil Scrum para garantizar entregas incrementales,
                    transparencia y adaptación continua. Cada sprint culmina con una demo funcional
                    y una retrospectiva para mejorar el proceso.
                </p>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-arrow-repeat text-primary fs-5 mt-1 flex-shrink-0"></i>
                            <div>
                                <div class="fw-semibold small">Sprints semanales</div>
                                <div class="text-muted small">Entregas iterativas</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-list-check text-success fs-5 mt-1 flex-shrink-0"></i>
                            <div>
                                <div class="fw-semibold small">Product Backlog</div>
                                <div class="text-muted small">40 PBIs organizados</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-chat-dots text-info fs-5 mt-1 flex-shrink-0"></i>
                            <div>
                                <div class="fw-semibold small">Daily Standup</div>
                                <div class="text-muted small">Sincronización diaria</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-trophy text-warning fs-5 mt-1 flex-shrink-0"></i>
                            <div>
                                <div class="fw-semibold small">Sprint Review</div>
                                <div class="text-muted small">Demo con stakeholders</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <!-- Épicas del backlog -->
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                    <div class="card-header bg-primary text-white fw-semibold py-3">
                        <i class="bi bi-kanban me-2"></i>Product Backlog — Épicas
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <i class="bi bi-shield-lock text-primary me-2"></i>
                                    <span class="fw-semibold">Épica 1</span>
                                    <span class="text-muted ms-2 small">Fundación, seguridad y administración</span>
                                </div>
                                <span class="badge text-bg-primary rounded-pill">PBI 01–10</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <i class="bi bi-tree text-success me-2"></i>
                                    <span class="fw-semibold">Épica 2</span>
                                    <span class="text-muted ms-2 small">Fincas, evaluación y pagos</span>
                                </div>
                                <span class="badge text-bg-success rounded-pill">PBI 11–30</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                <div>
                                    <i class="bi bi-graph-up text-warning me-2"></i>
                                    <span class="fw-semibold">Épica 3</span>
                                    <span class="text-muted ms-2 small">Dashboards, accesibilidad y calidad</span>
                                </div>
                                <span class="badge text-bg-warning rounded-pill">PBI 31–40</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-0 py-2 text-center">
                        <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>Entrega: 25 de Abril de 2026</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SECCIÓN 6 · CTA / UNIRSE -->
<section class="py-6 psa-stats-section text-white" id="contacto">
    <div class="container text-center">
        <h2 class="display-6 fw-bold mb-3">¿Quieres <span class="text-warning">conocer</span> el sistema?</h2>
        <p class="text-white-75 col-md-6 mx-auto mb-5">
            El Sistema Nativa está en desarrollo activo. Si eres propietario de finca y deseas
            participar como beta tester, ¡regístrate ya!
        </p>
        <div class="d-flex justify-content-center flex-wrap gap-3">
            <a href="/Register" class="btn btn-warning btn-lg px-5 fw-bold shadow">
                <i class="bi bi-person-plus me-2"></i>Crear mi cuenta
            </a>
            <a href="/Landing/Project" class="btn btn-outline-light btn-lg px-5">
                <i class="bi bi-arrow-left me-2"></i>Volver al inicio
            </a>
        </div>
    </div>
</section>
