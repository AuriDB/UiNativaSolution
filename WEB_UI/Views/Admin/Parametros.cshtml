@{
    ViewData["Title"] = "Parámetros de Pago PSA";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Admin" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-arrow-left me-1"></i>Usuarios
    </a>
    <div class="flex-fill">
        <h4 class="fw-bold mb-0"><i class="bi bi-sliders text-primary me-2"></i>Parámetros de Pago PSA</h4>
        <p class="text-muted mb-0 small">Configura los parámetros vigentes para el cálculo de pagos mensuales.</p>
    </div>
    <a href="/Admin/FincasAprobadas" class="btn btn-outline-success btn-sm rounded-3">
        <i class="bi bi-check2-circle me-1"></i>Activar Planes
    </a>
</div>

<div id="alertContainer" class="mb-3"></div>

<div class="row g-4">
    <!-- Formulario nuevo set de parámetros -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-plus-circle text-success me-2"></i>Configurar nueva Opción
                </h6>
                <p class="text-muted small mb-0">Al guardar, el set anterior dejará de ser vigente.</p>
            </div>
            <div class="card-body px-4 pb-4">

                <div class="mb-3">
                    <label class="form-label fw-semibold small">
                        Precio Base (₡/Hectárea) <span class="text-danger">*</span>
                    </label>
                    <input type="number" id="pPrecioBase" class="form-control rounded-3"
                           step="0.01" min="1" placeholder="Ej: 50000" />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Factores porcentuales</label>
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small text-muted">Vegetación</label>
                            <input type="number" id="pPctVeg" class="form-control rounded-3"
                                   step="0.0001" min="0" max="1" placeholder="0.1500" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted">Hidrología</label>
                            <input type="number" id="pPctHid" class="form-control rounded-3"
                                   step="0.0001" min="0" max="1" placeholder="0.1500" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted">Bono Nacional</label>
                            <input type="number" id="pPctNac" class="form-control rounded-3"
                                   step="0.0001" min="0" max="1" placeholder="0.1000" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small text-muted">Topografía</label>
                            <input type="number" id="pPctTop" class="form-control rounded-3"
                                   step="0.0001" min="0" max="1" placeholder="0.1000" />
                        </div>
                    </div>
                    <div class="form-text">Expresar como decimal. Ej: 15% = 0.1500</div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold small">
                        Tope máximo de bonificación <span class="text-danger">*</span>
                    </label>
                    <input type="number" id="pTope" class="form-control rounded-3"
                           step="0.01" min="0.01" max="1" placeholder="Ej: 0.50 (máximo 50%)" />
                    <div class="form-text">Decimal entre 0 y 1.</div>
                </div>

                <!-- Vista previa de la fórmula -->
                <div class="alert alert-light border rounded-3 small mb-4">
                    <strong>Fórmula:</strong><br>
                    <code>Monto = Hectáreas × PrecioBase × (1 + Min(SumaPct, Tope))</code><br>
                    <code>SumaPct = PctVeg + PctHid + (EsNacional ? PctNac : 0) + PctTop</code>
                </div>

                <button id="btnGuardarParametros" class="btn btn-success rounded-3 fw-semibold w-100">
                    <i class="bi bi-check-circle me-2"></i>Activar como parámetros vigentes
                </button>
            </div>
        </div>
    </div>

    <!-- Historial de parámetros -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-clock-history text-muted me-2"></i>Historial de configuraciones</h6>
            </div>
            <div class="card-body p-0">
                <div id="gridParametros" class="ag-theme-alpine"
                     style="height:480px;width:100%;border-radius:0 0 1rem 1rem;"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Admin/parametros.js" asp-append-version="true"></script>
}
