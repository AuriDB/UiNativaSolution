@{
    Layout = "_Layout";
    ViewData["Title"] = "Gestion de Usuarios";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-people-fill text-primary me-2"></i>Gestion de Usuarios
        </h4>
        <p class="text-muted mb-0">
            Total: <strong id="totalUsuarios">--</strong> usuarios registrados
        </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a href="/Admin/RegisterAdmin" class="btn btn-danger rounded-3">
            <i class="bi bi-person-fill-gear me-2"></i>Registrar Admin
        </a>
        <a href="/Admin/RegisterEngineer" class="btn btn-primary rounded-3">
            <i class="bi bi-person-badge me-2"></i>Registrar Ingeniero
        </a>
    </div>
</div>

<div id="alertContainer" class="mb-3"></div>

<div class="card border-0 shadow-sm rounded-4 mb-4">
    <div class="card-body p-3">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <label class="fw-semibold text-muted small mb-0">Filtrar por rol:</label>
            <select id="filtroRol" class="form-select form-select-sm rounded-3" style="width:200px;">
                <option value="">Todos los roles</option>
                <option value="1">Administrador</option>
                <option value="2">Ingeniero</option>
                <option value="3">Dueno</option>
            </select>
            <button id="btnRefresh" class="btn btn-sm btn-outline-secondary rounded-3">
                <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
            </button>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div class="table-responsive rounded-4">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 py-3 text-muted small fw-semibold">#</th>
                        <th class="py-3 text-muted small fw-semibold">Nombre</th>
                        <th class="py-3 text-muted small fw-semibold">Correo</th>
                        <th class="py-3 text-muted small fw-semibold">Cedula</th>
                        <th class="py-3 text-muted small fw-semibold">Rol</th>
                        <th class="py-3 text-muted small fw-semibold">Estado</th>
                        <th class="pe-4 py-3 text-muted small fw-semibold">Registro</th>
                    </tr>
                </thead>
                <tbody id="tbodyUsuarios">
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <span class="spinner-border spinner-border-sm me-2"></span>Cargando usuarios...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Admin/users.js" asp-append-version="true"></script>
}
