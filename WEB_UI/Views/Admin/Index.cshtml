@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <div class="flex-fill">
        <h4 class="fw-bold mb-0"><i class="bi bi-people text-primary me-2"></i>Gestión de Usuarios</h4>
        <p class="text-muted mb-0 small">Administra Ingenieros y Dueños del sistema.</p>
    </div>
    <a href="/Admin/Parametros" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-sliders me-1"></i>Parámetros PSA
    </a>
    <button class="btn btn-primary btn-sm rounded-3" data-bs-toggle="modal" data-bs-target="#modalCrear">
        <i class="bi bi-person-plus me-1"></i>Crear Ingeniero
    </button>
</div>

<div id="alertContainer" class="mb-3"></div>

<!-- Ag-Grid -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div id="gridUsuarios" class="ag-theme-alpine" style="height:520px;width:100%;border-radius:1rem;"></div>
    </div>
</div>

<!-- Modal: Crear Ingeniero -->
<div class="modal fade" id="modalCrear" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-person-badge text-primary me-2"></i>Nuevo Ingeniero
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <div id="alertModalCrear" class="mb-3"></div>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Nombre completo <span class="text-danger">*</span></label>
                    <input type="text" id="crNombre" class="form-control rounded-3" placeholder="Ej: Juan Pérez Mora" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Cédula <span class="text-danger">*</span></label>
                    <input type="text" id="crCedula" class="form-control rounded-3" placeholder="Ej: 1-1234-5678" maxlength="20" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Correo electrónico <span class="text-danger">*</span></label>
                    <input type="email" id="crCorreo" class="form-control rounded-3" placeholder="ingeniero@nativa.cr" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Contraseña inicial <span class="text-danger">*</span></label>
                    <input type="password" id="crContrasena" class="form-control rounded-3" placeholder="Mín. 6 chars, 1 mayús, 1 dígito" />
                    <div class="form-text">El ingeniero puede cambiarla usando "Olvidé mi contraseña".</div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">Cancelar</button>
                <button id="btnCrearIngeniero" class="btn btn-primary rounded-3 fw-semibold">
                    <i class="bi bi-check-circle me-1"></i>Crear cuenta
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Editar usuario -->
<div class="modal fade" id="modalEditar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-pencil text-warning me-2"></i>Editar Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <div id="alertModalEditar" class="mb-3"></div>
                <input type="hidden" id="editId" />

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Nombre completo <span class="text-danger">*</span></label>
                    <input type="text" id="editNombre" class="form-control rounded-3" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold small">Correo electrónico <span class="text-danger">*</span></label>
                    <input type="email" id="editCorreo" class="form-control rounded-3" />
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">Cancelar</button>
                <button id="btnGuardarEditar" class="btn btn-warning rounded-3 fw-semibold">
                    <i class="bi bi-check-circle me-1"></i>Guardar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Admin/usuarios.js" asp-append-version="true"></script>
}
