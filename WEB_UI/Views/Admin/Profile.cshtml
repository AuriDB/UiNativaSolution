@{
    Layout = "_Layout";
    ViewData["Title"] = "Mi Perfil";
    var userName = Context.Session.GetString("UserName") ?? "Administrador";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-2">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-person-circle text-primary me-2"></i>Mi Perfil
        </h4>
        <p class="text-muted mb-0">Bienvenido, <strong>@userName</strong></p>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <i class="bi bi-person-gear text-primary" style="font-size: 4rem;"></i>
                <h5 class="fw-bold mt-3 mb-2">Perfil de Administrador</h5>
                <p class="text-muted">Esta sección está en construcción.</p>
                <a href="/Admin/Dashboard" class="btn btn-primary rounded-3 mt-2">
                    <i class="bi bi-arrow-left me-2"></i>Volver al Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
