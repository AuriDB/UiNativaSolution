@{
    ViewData["Title"] = "Activar Planes de Pago";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Admin/Parametros" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-arrow-left me-1"></i>Parámetros
    </a>
    <div class="flex-fill">
        <h4 class="fw-bold mb-0"><i class="bi bi-check2-circle text-success me-2"></i>Activar Planes de Pago</h4>
        <p class="text-muted mb-0 small">Fincas aprobadas pendientes de activar su plan PSA.</p>
    </div>
</div>

<div id="alertContainer" class="mb-3"></div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div id="gridFincas" class="ag-theme-alpine" style="height:480px;width:100%;border-radius:1rem;"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Admin/fincasaprobadas.js" asp-append-version="true"></script>
}
