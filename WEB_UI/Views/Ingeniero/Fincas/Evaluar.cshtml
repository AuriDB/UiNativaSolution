@using WEB_UI.Models.Entities
@model Activo

@{
    Layout = "_Layout";
    ViewData["Title"] = $"Evaluar Finca #{Model.Id}";
}

<div class="mb-4">
    <a href="/Ingeniero/Cola" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-arrow-left me-1"></i>Volver a Cola
    </a>
    <h4 class="fw-bold mt-3 mb-1">
        <i class="bi bi-clipboard-check me-2 text-primary"></i>Evaluar Finca #@Model.Id
    </h4>
    <p class="text-muted small mb-0">Dueño: <strong>@Model.Dueno?.Nombre</strong> — Registrada el @Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm") UTC</p>
</div>

<div id="alertEvaluar"></div>

<div class="row g-4">
    <!-- Panel izquierdo: datos + APIs -->
    <div class="col-lg-8">
        <!-- Datos técnicos de la finca -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-clipboard-data me-2"></i>Datos Técnicos</h6>
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <div class="text-muted small">Hectáreas</div>
                            <div class="fw-bold fs-5">@Model.Hectareas.ToString("N4")</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <div class="text-muted small">Vegetación</div>
                            <div class="fw-bold fs-5">@Model.Vegetacion.ToString("N2")%</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <div class="text-muted small">Hidrología</div>
                            <div class="fw-bold fs-5">@Model.Hidrologia.ToString("N2")%</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <div class="text-muted small">Topografía</div>
                            <div class="fw-bold fs-5">@Model.Topografia.ToString("N2")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <div class="text-muted small">Bono Nacional</div>
                            <div class="fw-bold">
                                @if (Model.EsNacional)
                                { <span class="badge bg-success">Sí aplica</span> }
                                else
                                { <span class="badge bg-secondary">No aplica</span> }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <div class="text-muted small">Latitud</div>
                            <div class="fw-bold font-monospace">@Model.Lat</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 bg-light rounded-3 text-center">
                            <div class="text-muted small">Longitud</div>
                            <div class="fw-bold font-monospace">@Model.Lng</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- APIs externas -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-primary mb-0"><i class="bi bi-cloud-sun me-2"></i>Datos Ambientales (APIs)</h6>
                    <button id="btnCargarApis" class="btn btn-outline-primary btn-sm rounded-3">
                        <i class="bi bi-arrow-clockwise me-1"></i>Cargar
                    </button>
                </div>
                <div id="panelApis">
                    <p class="text-muted small text-center py-2">Presiona "Cargar" para obtener datos de clima y elevación.</p>
                </div>
            </div>
        </div>

        <!-- Adjuntos -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-paperclip me-2"></i>Documentos Adjuntos</h6>
                <div id="listaAdjuntos">
                    <div class="text-center text-muted py-3">
                        <div class="spinner-border spinner-border-sm me-2"></div>Cargando adjuntos...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Panel derecho: dictamen -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 1rem;">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-gavel me-2"></i>Dictamen</h6>

                <div class="mb-3">
                    <label class="form-label fw-semibold small">Observaciones</label>
                    <textarea id="txtObservaciones" class="form-control rounded-3" rows="5"
                              placeholder="Escribe tus observaciones técnicas...&#10;(obligatorio para Rechazar/Devolver)"></textarea>
                </div>

                <div class="d-grid gap-2">
                    <button id="btnAprobar" class="btn btn-success rounded-3 fw-semibold">
                        <i class="bi bi-check-circle me-2"></i>Aprobar Finca
                    </button>
                    <button id="btnDevolver" class="btn btn-warning rounded-3 fw-semibold">
                        <i class="bi bi-arrow-return-left me-2"></i>Devolver para Corrección
                    </button>
                    <button id="btnRechazar" class="btn btn-danger rounded-3 fw-semibold">
                        <i class="bi bi-x-circle me-2"></i>Rechazar (definitivo)
                    </button>
                </div>

                <hr class="my-3" />
                <button id="btnActivarPlan" class="btn btn-outline-success w-100 rounded-3 fw-semibold d-none">
                    <i class="bi bi-play-circle me-2"></i>Activar Plan de Pagos
                </button>
                <div id="estadoPlan" class="text-muted small text-center d-none"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const FINCA_ID = @Model.Id;
    </script>
    <script src="~/js/Pages/Ingeniero/evaluar.js" asp-append-version="true"></script>
}
