@model Nativa.Domain.Entities.Activo
@{
    ViewData["Title"] = $"Evaluar Finca #{Model.Id}";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Ingeniero/MisAsignadas" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-arrow-left me-1"></i>Mis Asignadas
    </a>
    <div class="flex-fill">
        <h4 class="fw-bold mb-0"><i class="bi bi-clipboard2-check text-primary me-2"></i>Evaluar Finca #@Model.Id</h4>
        <p class="text-muted mb-0 small">Emite tu dictamen técnico sobre esta finca.</p>
    </div>
</div>

<div id="alertContainer" class="mb-3"></div>

<div class="row g-4">

    <!-- Datos de la finca -->
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-clipboard-data text-primary me-2"></i>Datos de la Finca</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <dl class="row mb-0" id="dlDatos">
                    <dt class="col-5 text-muted small">Dueño</dt>
                    <dd class="col-7 fw-semibold" id="dNombreDueno">—</dd>

                    <dt class="col-5 text-muted small">Correo</dt>
                    <dd class="col-7" id="dCorreo">—</dd>

                    <dt class="col-5 text-muted small">Hectáreas</dt>
                    <dd class="col-7" id="dHectareas">—</dd>

                    <dt class="col-5 text-muted small">Vegetación</dt>
                    <dd class="col-7" id="dVegetacion">—</dd>

                    <dt class="col-5 text-muted small">Hidrología</dt>
                    <dd class="col-7" id="dHidrologia">—</dd>

                    <dt class="col-5 text-muted small">Topografía</dt>
                    <dd class="col-7" id="dTopografia">—</dd>

                    <dt class="col-5 text-muted small">Bono nacional</dt>
                    <dd class="col-7" id="dEsNacional">—</dd>

                    <dt class="col-5 text-muted small">F. Registro</dt>
                    <dd class="col-7" id="dFechaRegistro">—</dd>
                </dl>
            </div>
        </div>

        <!-- Adjuntos -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-paperclip text-primary me-2"></i>Adjuntos</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <div id="listaAdjuntos">
                    <div class="text-center text-muted py-2">
                        <i class="bi bi-hourglass-split fs-4 d-block mb-1"></i>Cargando...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Mapa + Dictamen -->
    <div class="col-lg-7">
        <!-- Mapa -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-geo-alt text-danger me-2"></i>Ubicación</h6>
            </div>
            <div class="card-body p-0">
                <div id="mapEvaluar" style="height:260px;border-radius:0 0 1rem 1rem;"></div>
            </div>
        </div>

        <!-- Formulario dictamen -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0"><i class="bi bi-journal-check text-success me-2"></i>Dictamen</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="mb-4">
                    <label class="form-label fw-semibold small">Decisión <span class="text-danger">*</span></label>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="dictamen" id="rdAprobar" value="Aprobar" />
                            <label class="form-check-label text-success fw-semibold" for="rdAprobar">
                                <i class="bi bi-check-circle me-1"></i>Aprobar
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="dictamen" id="rdDevolver" value="Devolver" />
                            <label class="form-check-label text-warning fw-semibold" for="rdDevolver">
                                <i class="bi bi-arrow-return-left me-1"></i>Devolver
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="dictamen" id="rdRechazar" value="Rechazar" />
                            <label class="form-check-label text-danger fw-semibold" for="rdRechazar">
                                <i class="bi bi-x-circle me-1"></i>Rechazar
                            </label>
                        </div>
                    </div>
                </div>

                <div class="mb-4" id="panelObservaciones" style="display:none;">
                    <label for="txtObservaciones" class="form-label fw-semibold small">
                        Observaciones <span class="text-danger">*</span>
                        <span class="text-muted fw-normal">(requeridas para Devolver/Rechazar)</span>
                    </label>
                    <textarea id="txtObservaciones" class="form-control rounded-3" rows="4"
                              placeholder="Detalla el motivo de la devolución o rechazo..."></textarea>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a href="/Ingeniero/MisAsignadas" class="btn btn-outline-secondary rounded-3">Cancelar</a>
                    <button id="btnDictamen" class="btn btn-primary rounded-3 fw-semibold">
                        <i class="bi bi-send me-2"></i>Emitir Dictamen
                    </button>
                </div>
            </div>
        </div>
    </div>

</div>

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/Pages/Ingeniero/evaluar.js" asp-append-version="true"></script>
    <script>
        $(document).ready(() => {
            const view = new EvaluarView(@Model.Id);
            view.InitView();
        });
    </script>
}
