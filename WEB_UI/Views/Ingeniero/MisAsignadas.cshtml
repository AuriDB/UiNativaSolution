@{
    ViewData["Title"] = "Mis Asignadas";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <div class="flex-fill">
        <h4 class="fw-bold mb-0"><i class="bi bi-clipboard-check text-success me-2"></i>Mis Fincas Asignadas</h4>
        <p class="text-muted mb-0 small">Fincas en revisión que tienes asignadas para dictamen.</p>
    </div>
    <a href="/Ingeniero" class="btn btn-outline-primary btn-sm rounded-3">
        <i class="bi bi-list-ol me-1"></i>Cola FIFO
    </a>
</div>

<div id="alertContainer" class="mb-3"></div>

<!-- Ag-Grid -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div id="gridAsignadas" class="ag-theme-alpine" style="height:520px;width:100%;border-radius:1rem;"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Ingeniero/misasignadas.js" asp-append-version="true"></script>
}
