@{
    Layout = "_Layout";
    ViewData["Title"] = "Cola de Evaluación";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-list-ol me-2 text-primary"></i>Cola de Evaluación (FIFO)</h4>
        <p class="text-muted small mb-0">Fincas pendientes ordenadas por fecha de registro (más antiguas primero)</p>
    </div>
    <button id="btnRefrescar" class="btn btn-outline-primary rounded-3 btn-sm fw-semibold">
        <i class="bi bi-arrow-clockwise me-1"></i>Actualizar Cola
    </button>
</div>

<div id="alertCola"></div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div id="gridCola" class="ag-theme-alpine" style="height: 520px; width: 100%;"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.3/dist/ag-grid-community.min.js"></script>
    <script src="~/js/Pages/Ingeniero/cola.js" asp-append-version="true"></script>
}
