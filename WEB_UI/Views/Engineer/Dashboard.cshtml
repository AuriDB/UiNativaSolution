@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    var userName = Context.Session.GetString("UserName") ?? "Ingeniero";
}

<!-- Encabezado -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-2">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-speedometer2 text-primary me-2"></i>Dashboard de Productividad
        </h4>
        <p class="text-muted mb-0">
            Bienvenido, <strong>@userName</strong> &mdash;
            @DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("es-CR"))
        </p>
    </div>
</div>

<div id="alertContainer"></div>

<!-- KPIs -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-info text-white fs-3 flex-shrink-0">
                    <i class="bi bi-list-task"></i>
                </div>
                <div>
                    <div class="text-muted small">Cola disponible</div>
                    <div class="fw-bold fs-3" id="statCola">—</div>
                    <div class="text-muted small">Fincas en espera</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-warning text-dark fs-3 flex-shrink-0">
                    <i class="bi bi-clipboard-check"></i>
                </div>
                <div>
                    <div class="text-muted small">Asignadas</div>
                    <div class="fw-bold fs-3" id="statAsignadas">—</div>
                    <div class="text-muted small">En revisión ahora</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-success text-white fs-3 flex-shrink-0">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Evaluaciones</div>
                    <div class="fw-bold fs-3" id="statEvaluaciones">—</div>
                    <div class="text-muted small">Realizadas en total</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-primary text-white fs-3 flex-shrink-0">
                    <i class="bi bi-map-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Hectáreas auditadas</div>
                    <div class="fw-bold fs-3" id="statHectareas">—</div>
                    <div class="text-muted small">Acumuladas</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fila inferior -->
<div class="row g-4">

    <!-- Fincas asignadas actualmente -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 px-4">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-clipboard text-primary me-2"></i>Fincas asignadas actualmente
                </h6>
                <a href="/Engineer/FifoQueue" class="btn btn-sm btn-outline-primary rounded-3">
                    <i class="bi bi-arrow-right me-1"></i>Ver cola completa
                </a>
            </div>
            <div class="card-body px-4 pb-4">
                <div id="tablaAsignadas">
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-hourglass-split fs-3 mb-2 d-block"></i>
                        Cargando fincas...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones rápidas -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-lightning-charge text-warning me-2"></i>Acciones rápidas
                </h6>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="d-grid gap-3">
                    <a href="/Engineer/FifoQueue"
                       class="btn btn-primary rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-list-task fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Ver cola FIFO</div>
                            <div class="small opacity-75">Tomar nueva solicitud</div>
                        </div>
                    </a>
                    <a href="/Engineer/History"
                       class="btn btn-outline-success rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-clock-history fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Historial de evaluaciones</div>
                            <div class="small opacity-75">Ver mis dictámenes</div>
                        </div>
                    </a>
                    <a href="/Engineer/Profile"
                       class="btn btn-outline-info rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-person-gear fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Mi perfil</div>
                            <div class="small opacity-75">Datos personales y preferencias</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/Pages/Engineer/dashboard.js" asp-append-version="true"></script>
}
