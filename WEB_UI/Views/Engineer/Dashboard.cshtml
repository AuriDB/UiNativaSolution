@{
    ViewData["Title"] = "Engineer Dashboard";
}

@inject IHttpContextAccessor Accessor
@{
    var userName = Accessor.HttpContext?.Session.GetString("UserName") ?? "Ingeniero";
    var userRole = Accessor.HttpContext?.Session.GetString("UserRole") ?? "Ingeniero";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-2">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-speedometer2 text-primary me-2"></i>Dashboard de Ingeniero
        </h4>
        <p class="text-muted mb-0">
            Bienvenido, <strong>@userName</strong> &mdash;
            @DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("es-CR"))
        </p>
    </div>
    <div>
        <span class="badge text-bg-primary px-3 py-2 fs-6">
            <i class="bi bi-person-badge me-1"></i>@userRole
        </span>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-warning text-dark fs-3 flex-shrink-0">
                    <i class="bi bi-hourglass-split"></i>
                </div>
                <div>
                    <div class="text-muted small">Solicitudes pendientes</div>
                    <div class="fw-bold fs-3">18</div>
                    <div class="text-muted small">En cola FIFO</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-info text-white fs-3 flex-shrink-0">
                    <i class="bi bi-search"></i>
                </div>
                <div>
                    <div class="text-muted small">En revisión</div>
                    <div class="fw-bold fs-3">6</div>
                    <div class="text-muted small">Asignadas a ti</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-success text-white fs-3 flex-shrink-0">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Aprobadas</div>
                    <div class="fw-bold fs-3">12</div>
                    <div class="text-muted small">Este mes</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-danger text-white fs-3 flex-shrink-0">
                    <i class="bi bi-arrow-return-left"></i>
                </div>
                <div>
                    <div class="text-muted small">Devueltas / rechazadas</div>
                    <div class="fw-bold fs-3">4</div>
                    <div class="text-muted small">Este mes</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 px-4">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-list-task text-primary me-2"></i>Solicitudes recientes
                </h6>
                <a href="/Engineer/FifoQueue" class="btn btn-sm btn-outline-primary rounded-3">
                    <i class="bi bi-arrow-right me-1"></i>Ver cola completa
                </a>
            </div>

            <div class="card-body px-4 pb-4">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Código</th>
                                <th>Finca</th>
                                <th>Propietario</th>
                                <th>Ubicación</th>
                                <th>Fecha</th>
                                <th>Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="fw-semibold">FIN-001</td>
                                <td>Finca El Bosque</td>
                                <td>María Rodríguez</td>
                                <td>San Carlos</td>
                                <td>18/03/2026</td>
                                <td><span class="badge bg-warning text-dark">Pendiente</span></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">FIN-002</td>
                                <td>Los Laureles</td>
                                <td>Carlos Méndez</td>
                                <td>Upala</td>
                                <td>17/03/2026</td>
                                <td><span class="badge bg-info text-dark">En revisión</span></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">FIN-003</td>
                                <td>Quebrada Verde</td>
                                <td>Ana Solís</td>
                                <td>Guatuso</td>
                                <td>16/03/2026</td>
                                <td><span class="badge bg-success">Aprobada</span></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">FIN-004</td>
                                <td>Monte Claro</td>
                                <td>José Ramírez</td>
                                <td>Sarapiquí</td>
                                <td>15/03/2026</td>
                                <td><span class="badge bg-secondary">Devuelta</span></td>
                            </tr>
                            <tr>
                                <td class="fw-semibold">FIN-005</td>
                                <td>Río Azul</td>
                                <td>Laura Vargas</td>
                                <td>San Ramón</td>
                                <td>14/03/2026</td>
                                <td><span class="badge bg-danger">Rechazada</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-lightning-charge text-warning me-2"></i>Acciones rápidas
                </h6>
            </div>

            <div class="card-body px-4 pb-4">
                <div class="d-grid gap-3">
                    <a href="/Engineer/FifoQueue" class="btn btn-primary rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-list-task fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Revisar cola FIFO</div>
                            <div class="small opacity-75">Tomar nuevas solicitudes</div>
                        </div>
                    </a>

                    <a href="/Engineer/History" class="btn btn-outline-success rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-clock-history fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Ver historial</div>
                            <div class="small opacity-75">Consulta evaluaciones anteriores</div>
                        </div>
                    </a>

                    <a href="/Perfil" class="btn btn-outline-info rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-person-gear fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Mi perfil</div>
                            <div class="small opacity-75">Actualiza tus datos</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>