@{
    Layout = "_Layout";
    ViewData["Title"] = "Evaluación de Finca";
    var fincaId = ViewBag.FincaId;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-clipboard-check text-primary me-2"></i>Evaluación de Finca
    </h4>
    <a href="/Engineer/FifoQueue" class="btn btn-outline-secondary rounded-3">
        <i class="bi bi-arrow-left me-2"></i>Volver a la Cola
    </a>
</div>

<div id="alertContainer"></div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-5 text-center">
        <i class="bi bi-clipboard-check text-primary" style="font-size: 4rem;"></i>
        <h5 class="fw-bold mt-3 mb-2">Formulario de Evaluación</h5>
        <p class="text-muted">Esta sección está en construcción.</p>
        <a href="/Engineer/Dashboard" class="btn btn-primary rounded-3 mt-2">
            <i class="bi bi-arrow-left me-2"></i>Volver al Dashboard
        </a>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Engineer/evaluation.js" asp-append-version="true"></script>
}
