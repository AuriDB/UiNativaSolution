@{
    ViewData["Title"] = "Mis Cuentas Bancarias";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Dueno" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-arrow-left me-1"></i>Mis fincas
    </a>
    <div class="flex-fill">
        <h4 class="fw-bold mb-0"><i class="bi bi-bank text-primary me-2"></i>Mis Cuentas Bancarias</h4>
        <p class="text-muted mb-0 small">Administra las cuentas IBAN para recibir tus pagos PSA.</p>
    </div>
    <button class="btn btn-primary btn-sm rounded-3" data-bs-toggle="modal" data-bs-target="#modalAgregar">
        <i class="bi bi-plus-circle me-1"></i>Agregar cuenta
    </button>
</div>

<div id="alertContainer" class="mb-3"></div>

<!-- Ag-Grid -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div id="gridCuentas" class="ag-theme-alpine" style="height:420px;width:100%;border-radius:1rem;"></div>
    </div>
</div>

<!-- Modal: Agregar cuenta -->
<div class="modal fade" id="modalAgregar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-bank text-primary me-2"></i>Nueva cuenta bancaria
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body px-4">
                <div id="alertModal" class="mb-3"></div>

                <div class="mb-3">
                    <label for="selBanco" class="form-label fw-semibold small">
                        Banco <span class="text-danger">*</span>
                    </label>
                    <select id="selBanco" class="form-select rounded-3">
                        <option value="">Selecciona un banco...</option>
                        <option>Banco Nacional de Costa Rica</option>
                        <option>Banco de Costa Rica</option>
                        <option>Banco Popular</option>
                        <option>Banco BAC Credomatic</option>
                        <option>Banco Scotiabank</option>
                        <option>Banco Davivienda</option>
                        <option>Otro</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="selTipo" class="form-label fw-semibold small">
                        Tipo de cuenta <span class="text-danger">*</span>
                    </label>
                    <select id="selTipo" class="form-select rounded-3">
                        <option value="">Selecciona...</option>
                        <option>Corriente</option>
                        <option>Ahorros</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label for="inpTitular" class="form-label fw-semibold small">
                        Titular <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="inpTitular" class="form-control rounded-3"
                           placeholder="Nombre completo del titular" />
                </div>

                <div class="mb-3">
                    <label for="inpIban" class="form-label fw-semibold small">
                        IBAN <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="inpIban" class="form-control rounded-3 font-monospace"
                           placeholder="CR21 0001 0002 0003 0004 5678"
                           maxlength="22" />
                    <div class="form-text">Formato: CR seguido de 20 dígitos (sin espacios).</div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">Cancelar</button>
                <button id="btnAgregarCuenta" class="btn btn-primary rounded-3 fw-semibold">
                    <i class="bi bi-check-circle me-1"></i>Guardar cuenta
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Dueno/cuentas.js" asp-append-version="true"></script>
}
