@{
    ViewData["Title"] = "Mis Fincas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-map text-primary me-2"></i>Mis Fincas</h4>
        <p class="text-muted mb-0">Gestiona tus propiedades registradas en el programa PSA.</p>
    </div>
    <a href="/Dueno/Registrar" class="btn btn-primary rounded-3 fw-semibold">
        <i class="bi bi-plus-circle me-2"></i>Registrar nueva finca
    </a>
</div>

<!-- Alertas -->
<div id="alertContainer" class="mb-3"></div>

<!-- Tabla Ag-Grid -->
<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div id="gridFincas" class="ag-theme-alpine rounded-4" style="height:480px;width:100%"></div>
    </div>
</div>

<!-- Modal confirmar cancelación -->
<div class="modal fade" id="modalCancelar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle text-warning me-2"></i>Cancelar finca</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted">¿Estás seguro de que deseas cancelar esta finca? Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary rounded-3" data-bs-dismiss="modal">No, conservar</button>
                <button type="button" id="btnConfirmarCancelar" class="btn btn-danger rounded-3 fw-semibold">
                    <i class="bi bi-x-circle me-1"></i>Sí, cancelar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Ag-Grid Community -->
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.3.2/dist/ag-grid-community.min.js"></script>
    <script src="~/js/Pages/Dueno/index.js" asp-append-version="true"></script>
}
