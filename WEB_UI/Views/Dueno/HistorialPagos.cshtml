@{
    ViewData["Title"] = "Historial de Pagos PSA";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Dueno" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-arrow-left me-1"></i>Mis fincas
    </a>
    <div class="flex-fill">
        <h4 class="fw-bold mb-0"><i class="bi bi-cash-stack text-success me-2"></i>Historial de Pagos PSA</h4>
        <p class="text-muted mb-0 small">Seguimiento de tus planes de pago y cuotas mensuales.</p>
    </div>
</div>

<div id="alertContainer" class="mb-3"></div>

<!-- Contenedor dinámico de planes -->
<div id="contenedorPlanes">
    <div class="text-center py-5 text-muted">
        <i class="bi bi-hourglass-split fs-2 d-block mb-2"></i>Cargando historial...
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Dueno/historial.js" asp-append-version="true"></script>
}
