@{
    Layout = "_Layout";
    ViewData["Title"] = "Mis Fincas";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1"><i class="bi bi-tree me-2 text-success"></i>Mis Fincas</h4>
        <p class="text-muted small mb-0">Listado de tus propiedades registradas en el programa Nativa</p>
    </div>
    <a href="/Dueno/Fincas/Nueva" class="btn btn-success rounded-3 fw-semibold">
        <i class="bi bi-plus-lg me-1"></i>Registrar Finca
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-0">
        <div id="gridFincas" class="ag-theme-alpine" style="height: 480px; width: 100%;"></div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/ag-grid-community@31.0.3/dist/ag-grid-community.min.js"></script>
    <script src="~/js/Pages/Dueno/fincas.js" asp-append-version="true"></script>
}
