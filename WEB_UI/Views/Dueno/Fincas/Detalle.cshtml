@using WEB_UI.Models.Entities
@using WEB_UI.Models.Enums
@model Activo

@{
    Layout = "_Layout";
    ViewData["Title"] = $"Finca #{Model.Id}";

    var estadoClass = Model.Estado switch {
        EstadoActivoEnum.Pendiente  => "bg-warning text-dark",
        EstadoActivoEnum.EnRevision => "bg-info text-white",
        EstadoActivoEnum.Aprobada   => "bg-success text-white",
        EstadoActivoEnum.Devuelta   => "bg-secondary text-white",
        EstadoActivoEnum.Rechazada  => "bg-danger text-white",
        EstadoActivoEnum.Vencida    => "bg-dark text-white",
        _ => "bg-secondary text-white"
    };
    var puedeEditar = Model.Estado == EstadoActivoEnum.Devuelta;
    var puedeReenviar = Model.Estado == EstadoActivoEnum.Devuelta;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <a href="/Dueno/Fincas" class="btn btn-outline-secondary btn-sm rounded-3 mb-2">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-tree me-2 text-success"></i>Finca #@Model.Id
            <span class="badge @estadoClass ms-2 fs-6">@Model.Estado.ToString()</span>
        </h4>
        <p class="text-muted small mb-0">Registrada el @Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm") UTC</p>
    </div>
    <div class="d-flex gap-2">
        @if (puedeReenviar)
        {
            <button id="btnReenviar" class="btn btn-warning rounded-3 fw-semibold">
                <i class="bi bi-send me-1"></i>Reenviar a Evaluación
            </button>
        }
    </div>
</div>

<div class="row g-4">
    <!-- Datos técnicos -->
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-clipboard-data me-2"></i>Datos Técnicos</h6>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3">
                            <div class="text-muted small">Hectáreas</div>
                            <div class="fw-bold fs-5">@Model.Hectareas.ToString("N4")</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3">
                            <div class="text-muted small">Cobertura Vegetal</div>
                            <div class="fw-bold fs-5">@Model.Vegetacion.ToString("N2")%</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3">
                            <div class="text-muted small">Cobertura Hídrica</div>
                            <div class="fw-bold fs-5">@Model.Hidrologia.ToString("N2")%</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3">
                            <div class="text-muted small">Índice Topográfico</div>
                            <div class="fw-bold fs-5">@Model.Topografia.ToString("N2")</div>
                        </div>
                    </div>
                    <div class="col-12">
                        <div class="p-3 bg-light rounded-3">
                            <div class="text-muted small">Bono Nacional</div>
                            <div class="fw-bold">
                                @if (Model.EsNacional)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check me-1"></i>Sí aplica</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No aplica</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3">
                            <div class="text-muted small">Latitud</div>
                            <div class="fw-bold">@Model.Lat</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 bg-light rounded-3">
                            <div class="text-muted small">Longitud</div>
                            <div class="fw-bold">@Model.Lng</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Observaciones + Adjuntos -->
    <div class="col-lg-6">
        @if (!string.IsNullOrWhiteSpace(Model.Observaciones))
        {
            <div class="card border-0 shadow-sm rounded-4 mb-4 border-start border-4 border-warning">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-warning mb-2"><i class="bi bi-exclamation-triangle me-2"></i>Observaciones del Ingeniero</h6>
                    <p class="mb-0">@Model.Observaciones</p>
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-paperclip me-2"></i>Documentos Adjuntos</h6>
                <div id="listaAdjuntos">
                    <div class="text-center text-muted py-3">
                        <div class="spinner-border spinner-border-sm me-2"></div>Cargando adjuntos...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Formulario edición (solo si Devuelta) -->
    @if (puedeEditar)
    {
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 border-top border-4 border-secondary">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-secondary mb-3"><i class="bi bi-pencil me-2"></i>Corregir Datos</h6>
                    <form id="frmEditar" enctype="multipart/form-data">
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Hectáreas</label>
                                <input type="number" name="hectareas" class="form-control rounded-3"
                                       step="0.0001" value="@Model.Hectareas" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Vegetación (%)</label>
                                <input type="number" name="vegetacion" class="form-control rounded-3"
                                       step="0.01" value="@Model.Vegetacion" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Hidrología (%)</label>
                                <input type="number" name="hidrologia" class="form-control rounded-3"
                                       step="0.01" value="@Model.Hidrologia" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Topografía</label>
                                <input type="number" name="topografia" class="form-control rounded-3"
                                       step="0.01" value="@Model.Topografia" required />
                            </div>
                            <div class="col-md-3">
                                <div class="form-check mt-3">
                                    <input class="form-check-input" type="checkbox" name="esNacional" id="esNacEdit"
                                           @(Model.EsNacional ? "checked" : "") />
                                    <label class="form-check-label small fw-semibold" for="esNacEdit">Bono nacional</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Latitud</label>
                                <input type="number" name="lat" class="form-control rounded-3"
                                       step="0.000001" value="@Model.Lat" required />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-semibold small">Longitud</label>
                                <input type="number" name="lng" class="form-control rounded-3"
                                       step="0.000001" value="@Model.Lng" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Observaciones propias</label>
                                <textarea name="observaciones" class="form-control rounded-3" rows="2"
                                          placeholder="Notas adicionales..."></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold small">Nuevos Adjuntos (opcional)</label>
                                <input type="file" name="archivos" class="form-control rounded-3"
                                       multiple accept=".jpg,.jpeg,.png,.pdf,.dwg" />
                            </div>
                        </div>
                        <button type="submit" id="btnEditar" class="btn btn-secondary rounded-3 fw-semibold mt-3">
                            <i class="bi bi-save me-1"></i>Guardar Correcciones
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        const FINCA_ID = @Model.Id;
        const PUEDE_REENVIAR = @puedeReenviar.ToString().ToLower();
    </script>
    <script src="~/js/Pages/Dueno/finca-detalle.js" asp-append-version="true"></script>
}
