@{
    Layout = "_Layout";
    ViewData["Title"] = "Registrar Finca";
}

<div class="mb-4">
    <a href="/Dueno/Fincas" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <h4 class="fw-bold mt-3 mb-1"><i class="bi bi-plus-circle me-2 text-success"></i>Registrar Nueva Finca</h4>
    <p class="text-muted small mb-0">Ingresa los datos de tu propiedad para iniciar el proceso de evaluación</p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-file-text me-2"></i>Datos de la Finca</h6>
                <form id="frmNuevaFinca" enctype="multipart/form-data" novalidate>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Hectáreas <span class="text-danger">*</span></label>
                            <input type="number" name="hectareas" id="hectareas" class="form-control rounded-3"
                                   step="0.0001" min="0.0001" placeholder="Ej: 15.5" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Cobertura Vegetal (%) <span class="text-danger">*</span></label>
                            <input type="number" name="vegetacion" id="vegetacion" class="form-control rounded-3"
                                   step="0.01" min="0" max="100" placeholder="Ej: 75.5" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Cobertura Hídrica (%) <span class="text-danger">*</span></label>
                            <input type="number" name="hidrologia" id="hidrologia" class="form-control rounded-3"
                                   step="0.01" min="0" max="100" placeholder="Ej: 30.0" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Índice Topográfico <span class="text-danger">*</span></label>
                            <input type="number" name="topografia" id="topografia" class="form-control rounded-3"
                                   step="0.01" min="0" max="100" placeholder="Ej: 45.0" required />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="esNacional" id="esNacional" />
                                <label class="form-check-label fw-semibold small" for="esNacional">
                                    Aplica bono nacional
                                    <i class="bi bi-info-circle text-muted ms-1" data-bs-toggle="tooltip"
                                       title="Marcar si la finca aplica para el bono de interés nacional"></i>
                                </label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Latitud <span class="text-danger">*</span></label>
                            <input type="number" name="lat" id="lat" class="form-control rounded-3"
                                   step="0.000001" placeholder="Ej: 9.748917" required readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold small">Longitud <span class="text-danger">*</span></label>
                            <input type="number" name="lng" id="lng" class="form-control rounded-3"
                                   step="0.000001" placeholder="Ej: -83.753428" required readonly />
                        </div>
                    </div>

                    <hr class="my-4" />
                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-paperclip me-2"></i>Documentos Adjuntos</h6>
                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Archivos (jpg, png, pdf, dwg — máx 10 MB c/u)</label>
                        <input type="file" name="archivos" id="archivos" class="form-control rounded-3"
                               multiple accept=".jpg,.jpeg,.png,.pdf,.dwg" />
                        <div class="form-text text-muted small">Puedes adjuntar planos, fotos y documentos legales.</div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <a href="/Dueno/Fincas" class="btn btn-outline-secondary rounded-3 fw-semibold">Cancelar</a>
                        <button type="submit" id="btnGuardar" class="btn btn-success flex-fill rounded-3 fw-semibold">
                            <i class="bi bi-check-lg me-2"></i>Registrar Finca
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-geo-alt me-2"></i>Ubicación en el Mapa</h6>
                <p class="text-muted small">Haz clic en el mapa para seleccionar la ubicación de tu finca.</p>
                <div id="mapNuevaFinca" style="height: 350px; border-radius: 12px; border: 1px solid #dee2e6;"></div>
                <div id="coordsInfo" class="mt-2 text-muted small d-none">
                    <i class="bi bi-pin-map me-1"></i>
                    <span id="coordsText"></span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/Pages/Dueno/nueva-finca.js" asp-append-version="true"></script>
}
