<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema Nativa</title>
    <link href="~/css/DemoMint.css.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

<!-- NAVBAR PÚBLICA -->
<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/Landing/Project">
            <i class="bi bi-tree-fill fs-4"></i><span>Sistema Nativa</span>
        </a>
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#navPublic">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navPublic">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Project" ? "active fw-semibold" : "")"
                       href="/Landing/Project">
                        <i class="bi bi-house me-1"></i>Inicio
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Team" ? "active fw-semibold" : "")"
                       href="/Landing/Team">
                        <i class="bi bi-people me-1"></i>Equipo
                    </a>
                </li>
            </ul>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Auth" asp-action="Login" class="btn btn-outline-light btn-sm px-3">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar Sesión
                </a>
                <a asp-controller="Auth" asp-action="Registro" class="btn btn-light btn-sm px-3 text-primary fw-semibold">
                    <i class="bi bi-person-plus me-1"></i>Registrarse
                </a>
            </div>
        </div>
    </div>
</nav>

<!-- CONTENIDO -->
<main class="flex-grow-1">
    @RenderBody()
</main>

<!-- FOOTER PÚBLICO -->
<footer class="bg-dark text-white py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <i class="bi bi-tree-fill text-success fs-4"></i>
                    <span class="fw-bold fs-5">Sistema Nativa</span>
                </div>
                <p class="text-white-50 small mb-0">
                    Plataforma para la gestión del Pago por Servicios Ambientales en Costa Rica.
                    Conservamos juntos el patrimonio natural.
                </p>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold mb-3">Accesos rápidos</h6>
                <ul class="list-unstyled mb-0">
                    <li class="mb-1"><a href="/Landing/Project" class="text-white-50 text-decoration-none small"><i class="bi bi-chevron-right me-1"></i>Sobre el programa</a></li>
                    <li class="mb-1"><a href="/Landing/Team" class="text-white-50 text-decoration-none small"><i class="bi bi-chevron-right me-1"></i>Equipo de desarrollo</a></li>
                    <li class="mb-1"><a asp-controller="Auth" asp-action="Registro" class="text-white-50 text-decoration-none small"><i class="bi bi-chevron-right me-1"></i>Crear cuenta</a></li>
                    <li class="mb-1"><a asp-controller="Auth" asp-action="Login" class="text-white-50 text-decoration-none small"><i class="bi bi-chevron-right me-1"></i>Iniciar sesión</a></li>
                </ul>
            </div>
            <div class="col-md-4">
                <h6 class="fw-semibold mb-3">Contacto</h6>
                <ul class="list-unstyled text-white-50 small mb-0">
                    <li class="mb-2"><i class="bi bi-geo-alt me-2 text-success"></i>Costa Rica</li>
                    <li class="mb-2"><i class="bi bi-envelope me-2 text-success"></i>soporte@sistemanativa.cr</li>
                    <li class="mb-2"><i class="bi bi-shield-check me-2 text-success"></i>Plataforma segura</li>
                </ul>
            </div>
        </div>
        <hr class="border-secondary mt-4 mb-3" />
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2">
            <span class="text-white-50 small">&copy; @DateTime.Now.Year Sistema Nativa &mdash; Todos los derechos reservados</span>
            <span class="text-white-50 small">Desarrollado con <i class="bi bi-heart-fill text-danger"></i> en Costa Rica</span>
        </div>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
