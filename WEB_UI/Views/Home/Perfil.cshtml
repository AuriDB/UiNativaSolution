@{
    Layout = "_Layout";
    ViewData["Title"] = "Mi Perfil";
}

<div class="mb-4">
    <a href="/Home" class="btn btn-outline-secondary btn-sm rounded-3 mb-2">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
    <h4 class="fw-bold mt-3 mb-1"><i class="bi bi-person-circle me-2 text-primary"></i>Mi Perfil</h4>
    <p class="text-muted small mb-0">Información de tu cuenta en el Sistema Nativa</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <div class="psa-icon-box bg-primary text-white fs-1 mx-auto mb-3" style="width:72px;height:72px;border-radius:50%;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <h5 class="fw-bold mb-1">@ViewBag.Nombre</h5>
                    <span class="badge text-bg-primary px-3 py-1">@ViewBag.Rol</span>
                </div>

                <hr />

                <div class="row g-3">
                    <div class="col-5 text-muted small fw-semibold">Nombre completo</div>
                    <div class="col-7 small">@ViewBag.Nombre</div>

                    <div class="col-5 text-muted small fw-semibold">Correo electrónico</div>
                    <div class="col-7 small font-monospace">@ViewBag.Correo</div>

                    <div class="col-5 text-muted small fw-semibold">Rol en el sistema</div>
                    <div class="col-7 small">@ViewBag.Rol</div>
                </div>

                <hr />

                <div class="text-center">
                    <a href="/Auth/OlvidoContrasena" class="btn btn-outline-secondary rounded-3 btn-sm">
                        <i class="bi bi-key me-1"></i>Cambiar contraseña
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
