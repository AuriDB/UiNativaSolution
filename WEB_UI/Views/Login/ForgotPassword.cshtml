@{
    Layout = "../Shared/_Layout_Auth.cshtml";
    ViewData["Title"] = "Recuperar Contraseña";
}

<div class="card border-0 shadow-sm rounded-4 psa-auth-card">
    <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
            <div class="psa-icon-circle bg-warning text-dark mx-auto mb-3">
                <i class="bi bi-key-fill"></i>
            </div>
            <h4 class="fw-bold mb-1">¿Olvidaste tu contraseña?</h4>
            <p class="text-muted small mb-0">
                Ingresa tu correo y te enviaremos un enlace para restablecerla.
                El enlace expira en <strong>15 minutos</strong>.
            </p>
        </div>

        <div id="alertContainer"></div>

        <!-- Paso 1: Formulario correo -->
        <div id="stepCorreo">
            <form id="frmForgot" novalidate>
                <div class="mb-4">
                    <label for="correo" class="form-label fw-semibold small">
                        <i class="bi bi-envelope me-1 text-primary"></i>Correo electrónico
                    </label>
                    <input type="email" id="correo" name="correo"
                           class="form-control form-control-lg rounded-3"
                           placeholder="ejemplo@correo.com" required />
                </div>
                <button type="submit" id="btnEnviar" class="btn btn-primary btn-lg w-100 rounded-3 fw-semibold">
                    <i class="bi bi-send me-2"></i>Enviar enlace de recuperación
                </button>
            </form>
        </div>

        <!-- Paso 2: Confirmación (oculto hasta enviar) -->
        <div id="stepConfirmacion" class="d-none">
            <div class="text-center py-3">
                <i class="bi bi-envelope-check-fill text-success display-4 mb-3 d-block"></i>
                <h5 class="fw-bold text-success">¡Enlace enviado!</h5>
                <p class="text-muted small mb-0">
                    Si el correo está registrado, recibirás un enlace en los próximos minutos.
                    Revisa también tu carpeta de spam.
                </p>
            </div>
        </div>

        <hr class="my-4" />
        <p class="text-center text-muted small mb-0">
            <a href="/Login" class="text-primary text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i>Volver al inicio de sesión
            </a>
        </p>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Login/forgotpassword.js" asp-append-version="true"></script>
}
