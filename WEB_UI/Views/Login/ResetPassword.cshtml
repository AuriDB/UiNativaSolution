@{
    Layout = "../Shared/_Layout_Auth.cshtml";
    ViewData["Title"] = "Nueva Contraseña";
}

<div class="card border-0 shadow-sm rounded-4 psa-auth-card">
    <div class="card-body p-4 p-md-5">
        <div class="text-center mb-4">
            <div class="psa-icon-circle bg-success text-white mx-auto mb-3">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h4 class="fw-bold mb-1">Nueva contraseña</h4>
            <p class="text-muted small mb-0">Elige una contraseña segura para tu cuenta.</p>
        </div>

        <div id="alertContainer"></div>

        <form id="frmReset" novalidate>
            <input type="hidden" id="token" name="token" value="@Context.Request.Query["token"]" />

            <div class="mb-3">
                <label for="nuevaContrasena" class="form-label fw-semibold small">
                    <i class="bi bi-lock me-1 text-primary"></i>Nueva contraseña
                </label>
                <div class="input-group">
                    <input type="password" id="nuevaContrasena" name="nuevaContrasena"
                           class="form-control form-control-lg rounded-start-3"
                           placeholder="Mínimo 8 caracteres" required />
                    <button class="btn btn-outline-secondary" type="button" id="btnToggle1">
                        <i class="bi bi-eye" id="eye1"></i>
                    </button>
                </div>
            </div>

            <!-- Indicador de fortaleza -->
            <div class="mb-3">
                <div class="d-flex gap-1 mb-1">
                    <div class="psa-pwd-strength-bar flex-fill rounded" id="str1"></div>
                    <div class="psa-pwd-strength-bar flex-fill rounded" id="str2"></div>
                    <div class="psa-pwd-strength-bar flex-fill rounded" id="str3"></div>
                    <div class="psa-pwd-strength-bar flex-fill rounded" id="str4"></div>
                </div>
                <small id="strengthLabel" class="text-muted">Ingresa tu contraseña</small>
            </div>

            <!-- Política de contraseñas -->
            <div class="mb-4 p-3 bg-light rounded-3">
                <p class="text-muted small fw-semibold mb-2">La contraseña debe tener:</p>
                <div class="row g-1">
                    <div class="col-6"><small id="req-len" class="text-muted"><i class="bi bi-x-circle me-1"></i>Mínimo 6 caracteres</small></div>
                    <div class="col-6"><small id="req-upper" class="text-muted"><i class="bi bi-x-circle me-1"></i>Una mayúscula</small></div>
                    <div class="col-6"><small id="req-lower" class="text-muted"><i class="bi bi-x-circle me-1"></i>Una minúscula</small></div>
                    <div class="col-6"><small id="req-num" class="text-muted"><i class="bi bi-x-circle me-1"></i>Un número</small></div>
                    <div class="col-6"><small id="req-special" class="text-muted"><i class="bi bi-x-circle me-1"></i>Un carácter especial</small></div>
                    <div class="col-6"><small id="req-space" class="text-muted"><i class="bi bi-x-circle me-1"></i>Sin espacios</small></div>
                </div>
            </div>

            <div class="mb-4">
                <label for="confirmarContrasena" class="form-label fw-semibold small">
                    <i class="bi bi-lock-fill me-1 text-primary"></i>Confirmar contraseña
                </label>
                <div class="input-group">
                    <input type="password" id="confirmarContrasena" name="confirmarContrasena"
                           class="form-control form-control-lg rounded-start-3"
                           placeholder="Repite tu contraseña" required />
                    <button class="btn btn-outline-secondary" type="button" id="btnToggle2">
                        <i class="bi bi-eye" id="eye2"></i>
                    </button>
                </div>
            </div>

            <button type="submit" id="btnReset" class="btn btn-success btn-lg w-100 rounded-3 fw-semibold" disabled>
                <i class="bi bi-check-circle me-2"></i>Establecer nueva contraseña
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Login/resetpassword.js" asp-append-version="true"></script>
}
