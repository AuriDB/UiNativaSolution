@{
    Layout = "_Layout";
    ViewData["Title"] = "Cuenta Bancaria";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-credit-card text-primary me-2"></i>Cuenta Bancaria
    </h4>
</div>

<div id="alertContainer"></div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-5 text-center">
                <i class="bi bi-credit-card text-primary" style="font-size: 4rem;"></i>
                <h5 class="fw-bold mt-3 mb-2">Gestión de IBAN</h5>
                <p class="text-muted">Esta sección está en construcción.</p>
                <a href="/Owner/Dashboard" class="btn btn-primary rounded-3 mt-2">
                    <i class="bi bi-arrow-left me-2"></i>Volver al Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Owner/bank-account.js" asp-append-version="true"></script>
}
