@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard";
    var userName = Context.Session.GetString("UserName") ?? "Usuario";
}

<!-- Encabezado -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-2">
    <div>
        <h4 class="fw-bold mb-1">
            <i class="bi bi-speedometer2 text-primary me-2"></i>Mi Dashboard
        </h4>
        <p class="text-muted mb-0">
            Bienvenido, <strong>@userName</strong> &mdash;
            @DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("es-CR"))
        </p>
    </div>
</div>

<div id="alertContainer"></div>

<!-- KPIs -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-primary text-white fs-3 flex-shrink-0">
                    <i class="bi bi-map-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Mis fincas</div>
                    <div class="fw-bold fs-3" id="statFincas">—</div>
                    <div class="text-muted small">Registradas</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-success text-white fs-3 flex-shrink-0">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <div>
                    <div class="text-muted small">Fincas activas</div>
                    <div class="fw-bold fs-3" id="statActivas">—</div>
                    <div class="text-muted small">Con plan activo</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-warning text-dark fs-3 flex-shrink-0">
                    <i class="bi bi-cash-coin"></i>
                </div>
                <div>
                    <div class="text-muted small">Próximo pago</div>
                    <div class="fw-bold fs-5" id="statProximoPago">—</div>
                    <div class="text-muted small" id="statFechaPago">—</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-lg-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="psa-icon-box bg-info text-white fs-3 flex-shrink-0">
                    <i class="bi bi-clock-history"></i>
                </div>
                <div>
                    <div class="text-muted small">En revisión</div>
                    <div class="fw-bold fs-3" id="statEnRevision">—</div>
                    <div class="text-muted small">Pendientes de dictamen</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Fila inferior -->
<div class="row g-4">

    <!-- Fincas recientes -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center pt-4 px-4">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-map text-primary me-2"></i>Mis fincas recientes
                </h6>
                <a href="/Owner/MyProperties" class="btn btn-sm btn-outline-primary rounded-3">
                    <i class="bi bi-arrow-right me-1"></i>Ver todas
                </a>
            </div>
            <div class="card-body px-4 pb-4">
                <div id="tablaFincas">
                    <div class="text-center py-4 text-muted">
                        <i class="bi bi-hourglass-split fs-3 mb-2 d-block"></i>
                        Cargando fincas...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones rápidas -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-lightning-charge text-warning me-2"></i>Acciones rápidas
                </h6>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="d-grid gap-3">
                    <a href="/Owner/RegisterProperty"
                       class="btn btn-primary rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-plus-circle fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Registrar nueva finca</div>
                            <div class="small opacity-75">Inicia el proceso PSA</div>
                        </div>
                    </a>
                    <a href="/Owner/PaymentHistory"
                       class="btn btn-outline-success rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-receipt fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Historial de pagos</div>
                            <div class="small opacity-75">Consulta tus comprobantes</div>
                        </div>
                    </a>
                    <a href="/Owner/BankAccount"
                       class="btn btn-outline-warning rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-credit-card fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Cuenta bancaria</div>
                            <div class="small opacity-75">Actualizar IBAN</div>
                        </div>
                    </a>
                    <a href="/Owner/Profile"
                       class="btn btn-outline-info rounded-3 text-start d-flex align-items-center gap-3">
                        <i class="bi bi-person-gear fs-4 flex-shrink-0"></i>
                        <div>
                            <div class="fw-semibold">Mi perfil</div>
                            <div class="small opacity-75">Datos personales y preferencias</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="~/js/Pages/Owner/dashboard.js" asp-append-version="true"></script>
}