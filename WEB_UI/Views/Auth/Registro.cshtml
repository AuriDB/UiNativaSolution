@{
    Layout = "_Layout_Auth";
    ViewData["Title"] = "Registrarse";
}

<div class="card border-0 shadow-sm rounded-4 psa-auth-card psa-auth-card-wide">
    <div class="card-body p-4 p-md-5">
        <h4 class="fw-bold mb-1 text-center">Crear cuenta</h4>
        <p class="text-muted text-center small mb-4">Regístrate como Dueño de Propiedad</p>

        <div id="alertContainer"></div>

        <!-- Indicador de pasos -->
        <div class="d-flex align-items-center justify-content-center gap-2 mb-4">
            <div class="psa-step-dot psa-step-dot-active" id="dot1"><span>1</span></div>
            <div class="psa-step-line flex-fill"></div>
            <div class="psa-step-dot" id="dot2"><span>2</span></div>
            <div class="psa-step-line flex-fill"></div>
            <div class="psa-step-dot" id="dot3"><span>3</span></div>
        </div>
        <div class="d-flex justify-content-between text-center mb-4">
            <small class="text-muted col-4" id="lbl1">Datos personales</small>
            <small class="text-muted col-4" id="lbl2">Contraseña</small>
            <small class="text-muted col-4" id="lbl3">Confirmar</small>
        </div>

        <form id="frmRegister" novalidate>

            <!-- PASO 1: Datos personales -->
            <div id="step1">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="nombre" class="form-label fw-semibold small">
                            <i class="bi bi-person me-1 text-primary"></i>Nombre
                        </label>
                        <input type="text" id="nombre" name="nombre"
                               class="form-control rounded-3" placeholder="Ej: Juan" required />
                    </div>
                    <div class="col-md-6">
                        <label for="apellido1" class="form-label fw-semibold small">
                            <i class="bi bi-person me-1 text-primary"></i>Apellido 1
                        </label>
                        <input type="text" id="apellido1" name="apellido1"
                               class="form-control rounded-3" placeholder="Ej: Pérez" required />
                    </div>
                    <div class="col-md-6">
                        <label for="apellido2" class="form-label fw-semibold small">
                            <i class="bi bi-person me-1 text-primary"></i>Apellido 2
                        </label>
                        <input type="text" id="apellido2" name="apellido2"
                               class="form-control rounded-3" placeholder="Ej: González" required />
                    </div>
                    <div class="col-12">
                        <label for="cedula" class="form-label fw-semibold small">
                            <i class="bi bi-card-text me-1 text-primary"></i>Cédula de identidad
                        </label>
                        <input type="text" id="cedula" name="cedula"
                               class="form-control rounded-3" placeholder="Ej: 1-2345-6789"
                               maxlength="12" required />
                        <div class="form-text text-muted small">Una vez registrada, la cédula no puede modificarse.</div>
                    </div>
                    <div class="col-12">
                        <label for="correo" class="form-label fw-semibold small">
                            <i class="bi bi-envelope me-1 text-primary"></i>Correo electrónico
                        </label>
                        <input type="email" id="correo" name="correo"
                               class="form-control rounded-3" placeholder="ejemplo@correo.com" required />
                        <div class="form-text text-muted small">El correo no puede modificarse después del registro.</div>
                    </div>
                </div>
                <button type="button" id="btnStep1" class="btn btn-primary w-100 rounded-3 mt-4 fw-semibold">
                    Siguiente <i class="bi bi-arrow-right ms-1"></i>
                </button>
            </div>

            <!-- PASO 2: Contraseña -->
            <div id="step2" class="d-none">
                <div class="mb-3">
                    <label for="contrasena" class="form-label fw-semibold small">
                        <i class="bi bi-lock me-1 text-primary"></i>Contraseña
                    </label>
                    <div class="input-group">
                        <input type="password" id="contrasena" name="contrasena"
                               class="form-control rounded-start-3" placeholder="Mínimo 6 caracteres" required />
                        <button class="btn btn-outline-secondary" type="button" id="btnTogglePwd">
                            <i class="bi bi-eye" id="eyePwd"></i>
                        </button>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex gap-1 mb-1">
                        <div class="psa-pwd-strength-bar flex-fill rounded" id="str1"></div>
                        <div class="psa-pwd-strength-bar flex-fill rounded" id="str2"></div>
                        <div class="psa-pwd-strength-bar flex-fill rounded" id="str3"></div>
                        <div class="psa-pwd-strength-bar flex-fill rounded" id="str4"></div>
                    </div>
                    <small id="strengthLabel" class="text-muted">Ingresa tu contraseña</small>
                </div>
                <div class="mb-3 p-3 bg-light rounded-3">
                    <p class="text-muted small fw-semibold mb-2">Requisitos:</p>
                    <div class="row g-1">
                        <div class="col-6"><small id="req-len"     class="text-muted"><i class="bi bi-x-circle me-1"></i>Mínimo 6 caracteres</small></div>
                        <div class="col-6"><small id="req-upper"   class="text-muted"><i class="bi bi-x-circle me-1"></i>Una mayúscula</small></div>
                        <div class="col-6"><small id="req-lower"   class="text-muted"><i class="bi bi-x-circle me-1"></i>Una minúscula</small></div>
                        <div class="col-6"><small id="req-num"     class="text-muted"><i class="bi bi-x-circle me-1"></i>Un número</small></div>
                        <div class="col-6"><small id="req-special" class="text-muted"><i class="bi bi-x-circle me-1"></i>Un carácter especial</small></div>
                        <div class="col-6"><small id="req-noname"  class="text-muted"><i class="bi bi-x-circle me-1"></i>Sin tu nombre</small></div>
                    </div>
                </div>
                <div class="mb-4">
                    <label for="confirmarContrasena" class="form-label fw-semibold small">
                        <i class="bi bi-lock-fill me-1 text-primary"></i>Confirmar contraseña
                    </label>
                    <input type="password" id="confirmarContrasena" name="confirmarContrasena"
                           class="form-control rounded-3" placeholder="Repite tu contraseña" required />
                </div>
                <div class="d-flex gap-2">
                    <button type="button" id="btnBack1" class="btn btn-outline-secondary rounded-3 fw-semibold">
                        <i class="bi bi-arrow-left me-1"></i>Atrás
                    </button>
                    <button type="button" id="btnStep2" class="btn btn-primary flex-fill rounded-3 fw-semibold" disabled>
                        Siguiente <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                </div>
            </div>

            <!-- PASO 3: Confirmar -->
            <div id="step3" class="d-none">
                <div class="card bg-light border-0 rounded-3 p-4 mb-4">
                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-person-check me-2"></i>Resumen de tu cuenta</h6>
                    <div class="row g-2">
                        <div class="col-5 text-muted small">Nombre:</div>
                        <div class="col-7 fw-semibold small" id="resumeNombre">—</div>
                        <div class="col-5 text-muted small">Apellido 1:</div>
                        <div class="col-7 fw-semibold small" id="resumeApellido1">—</div>
                        <div class="col-5 text-muted small">Apellido 2:</div>
                        <div class="col-7 fw-semibold small" id="resumeApellido2">—</div>
                        <div class="col-5 text-muted small">Cédula:</div>
                        <div class="col-7 fw-semibold small" id="resumeCedula">—</div>
                        <div class="col-5 text-muted small">Correo:</div>
                        <div class="col-7 fw-semibold small" id="resumeCorreo">—</div>
                    </div>
                </div>
                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" id="chkTerminos" required />
                    <label class="form-check-label text-muted small" for="chkTerminos">
                        Acepto los <a href="#" class="text-primary">términos y condiciones</a> del programa Nativa.
                    </label>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" id="btnBack2" class="btn btn-outline-secondary rounded-3 fw-semibold">
                        <i class="bi bi-arrow-left me-1"></i>Atrás
                    </button>
                    <button type="submit" id="btnRegister" class="btn btn-success flex-fill rounded-3 fw-semibold" disabled>
                        <i class="bi bi-person-plus me-2"></i>Crear mi cuenta
                    </button>
                </div>
            </div>
        </form>

        <hr class="my-4" />
        <p class="text-center text-muted small mb-0">
            ¿Ya tienes cuenta?
            <a href="/Auth/Login" class="text-primary fw-semibold text-decoration-none">Iniciar sesión</a>
        </p>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Register/register.js" asp-append-version="true"></script>
}
