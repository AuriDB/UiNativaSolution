@{
    Layout = "_Layout_Auth";
    ViewData["Title"] = "Iniciar Sesión";
}

<div class="card border-0 shadow-sm rounded-4 psa-auth-card">
    <div class="card-body p-4 p-md-5">
        <h4 class="fw-bold mb-1 text-center">Bienvenido de vuelta</h4>
        <p class="text-muted text-center small mb-4">Ingresa tus credenciales para continuar</p>

        <div id="alertContainer"></div>

        <form id="frmLogin" novalidate>
            <div class="mb-3">
                <label for="correo" class="form-label fw-semibold small">
                    <i class="bi bi-envelope me-1 text-primary"></i>Correo electrónico
                </label>
                <input type="email" id="correo" name="correo"
                       class="form-control form-control-lg rounded-3"
                       placeholder="ejemplo@correo.com"
                       autocomplete="username" required />
            </div>
            <div class="mb-4">
                <label for="contrasena" class="form-label fw-semibold small">
                    <i class="bi bi-lock me-1 text-primary"></i>Contraseña
                </label>
                <div class="input-group">
                    <input type="password" id="contrasena" name="contrasena"
                           class="form-control form-control-lg rounded-start-3"
                           placeholder="Tu contraseña"
                           autocomplete="current-password" required />
                    <button class="btn btn-outline-secondary" type="button" id="btnTogglePwd"
                            aria-label="Mostrar/ocultar contraseña">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="recordarme" />
                    <label class="form-check-label text-muted small" for="recordarme">Recordarme</label>
                </div>
                <a href="/Auth/OlvidoContrasena" class="small text-primary text-decoration-none">
                    ¿Olvidé mi contraseña?
                </a>
            </div>

            <button type="submit" id="btnLogin" class="btn btn-primary btn-lg w-100 rounded-3 fw-semibold">
                <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
            </button>
        </form>

        <hr class="my-4" />

        <p class="text-center text-muted small mb-0">
            ¿No tienes cuenta?
            <a href="/Auth/Registro" class="text-primary fw-semibold text-decoration-none">Regístrate aquí</a>
        </p>
    </div>
</div>

@section Scripts {
    <script src="~/js/Pages/Login/login.js" asp-append-version="true"></script>
}
